{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@clawchat/core": ["packages/core/src"],
      "@clawchat/p2p": ["packages/p2p/src"],
      "@clawchat/task": ["packages/task/src"],
      "@clawchat/storage": ["packages/storage/src"],
      "@clawchat/dht": ["packages/dht/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/node_modules", "**/dist"]
}