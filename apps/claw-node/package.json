{
  "name": "@clawchat/node",
  "version": "0.0.1",
  "description": "ClawChat Node - Orchestrated agent runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "claw-node": "./dist/bin.js" },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/bin.js",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawchat/core": "workspace:*",
    "@clawchat/p2p": "workspace:*",
    "@clawchat/storage": "workspace:*",
    "@clawchat/task": "workspace:*",
    "@clawchat/dht": "workspace:*",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "pino": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  }
}
