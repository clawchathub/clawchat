{
  "name": "clawchat",
  "version": "0.0.1",
  "private": true,
  "description": "Decentralized AI Agent Communication Network based on A2A Protocol",
  "keywords": ["a2a", "agent", "p2p", "decentralized", "ai"],
  "author": "ClawChat Team",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "vitest run --config tests/vitest.config.ts",
    "test:all": "pnpm -r test && pnpm test:e2e",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}